# -----------------------------------------------------------
# Production Management — Environment Configuration
# -----------------------------------------------------------
# Backend server port (Express + Socket.IO + SQLite API)
PORT=5907

# MQTT broker ports for edge device communication
MQTT_TCP_PORT=5908
MQTT_WS_PORT=5909

# SSR production frontend port
SSR_PORT=3002

# Frontend Vite dev server port
VITE_DEV_PORT=5177

# Exposed to frontend via import.meta.env.VITE_API_PORT
VITE_API_PORT=5907

# Path to SQLite database (default: ./oee_central.sqlite)
# DB_PATH=C:\data\oee_central.sqlite

# Path to cloudflared config YAML (optional, overrides USERPROFILE default)
# CLOUDFLARED_CONFIG=
